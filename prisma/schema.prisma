generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================
// 📱 APP CLIENTS (Usuários do Mobile)
// ==========================================================
model app_clients {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  phone        String   @unique @db.VarChar(20)
  pin_hash     String   @db.VarChar(255)
  
  // Perfil do Cliente
  avatar_url   String?  @db.Text 
  
  push_token   String?  @db.VarChar(255)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  // Relações
  favorites    client_favorites[]
  appointments appointments[]
  reviews      reviews[]
}

// ==========================================================
// ❤️ FAVORITOS
// ==========================================================
model client_favorites {
  id         String      @id @default(uuid()) @db.Uuid
  client_id  String      @db.Uuid
  tenant_id  String      @db.Uuid
  created_at DateTime    @default(now()) @db.Timestamptz(6)

  client     app_clients @relation(fields: [client_id], references: [id], onDelete: Cascade)
  tenant     tenants     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([client_id, tenant_id])
}

// ==========================================================
// 🏢 TENANTS (Barbearias) - Com Perfil e Endereço
// ==========================================================
model tenants {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(50)
  plan_status     String?   @default("trial") @db.VarChar(20)
  
  // Perfil da Barbearia
  logo_url        String?   @db.Text
  cover_url       String?   @db.Text
  description     String?   @db.Text
  phone           String?   @db.VarChar(20) // WhatsApp da loja

  // Endereço (Normalizado)
  address         String?   @db.VarChar(255) // Rua/Avenida
  address_num     String?   @db.VarChar(20)
  neighborhood    String?   @db.VarChar(100)
  city            String?   @db.VarChar(100)
  state           String?   @db.VarChar(2)   // UF (SP, RJ)
  zip_code        String?   @db.VarChar(20)  // CEP
  
  // Geolocalização
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)

  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  // Relações
  appointments    appointments[]
  blocked_slots   blocked_slots[]
  customers       customers[]
  operating_hours operating_hours[]
  services        services[]
  users           users[]
  favorited_by    client_favorites[]
  reviews         reviews[]
}

// ==========================================================
// 📅 APPOINTMENTS (Agendamentos)
// ==========================================================
model appointments {
  id                      String    @id @default(uuid()) @db.Uuid
  tenant_id               String?   @db.Uuid
  
  // Link Inteligente: Cliente do App OU Cliente Avulso
  app_client_id           String?   @db.Uuid
  customer_id             String?   @db.Uuid
  
  professional_id         String?   @db.Uuid
  service_id              String?   @db.Uuid
  
  start_time              DateTime  @db.Timestamptz(6)
  end_time                DateTime  @db.Timestamptz(6)
  
  status                  String?   @default("scheduled") @db.VarChar(20)
  total_price             Decimal?  @db.Decimal(10, 2)
  
  reminder_sent           Boolean?  @default(false)
  feedback_sent           Boolean?  @default(false)
  
  original_appointment_id String?   @db.Uuid
  reschedule_count        Int?      @default(0)
  
  created_at              DateTime? @default(now()) @db.Timestamptz(6)
  updated_at              DateTime? @default(now()) @db.Timestamptz(6)

  // Relações
  app_client              app_clients?  @relation(fields: [app_client_id], references: [id], onDelete: SetNull)
  customers               customers?    @relation(fields: [customer_id], references: [id], onDelete: NoAction)
  appointments            appointments? @relation("appointmentsToappointments", fields: [original_appointment_id], references: [id], onDelete: NoAction)
  other_appointments      appointments[] @relation("appointmentsToappointments")
  users                   users?        @relation(fields: [professional_id], references: [id], onDelete: NoAction)
  services                services?     @relation(fields: [service_id], references: [id], onDelete: NoAction)
  tenants                 tenants?      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, start_time], map: "idx_appointments_date")
}

// ==========================================================
// 👥 OUTRAS TABELAS (Users, Services, etc)
// ==========================================================

model users {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String?   @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  role          String?   @default("admin") @db.VarChar(20)
  active        Boolean?  @default(true)
  push_token    String?   @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  appointments  appointments[]
  blocked_slots blocked_slots[]
  tenants       tenants?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model services {
  id               String    @id @default(uuid()) @db.Uuid
  tenant_id        String?   @db.Uuid
  name             String    @db.VarChar(100)
  description      String?   @db.Text
  price            Decimal   @db.Decimal(10, 2)
  duration_minutes Int
  active           Boolean?  @default(true)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  appointments     appointments[]
  tenants          tenants?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model customers {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String?   @db.Uuid
  name          String    @db.VarChar(255)
  phone         String    @db.VarChar(20)
  notes         String?   @db.Text
  last_visit_at DateTime? @db.Timestamptz(6)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  appointments  appointments[]
  tenants       tenants?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([phone, tenant_id], map: "idx_customers_phone_tenant")
}

model blocked_slots {
  id         String    @id @default(uuid()) @db.Uuid
  tenant_id  String?   @db.Uuid
  user_id    String?   @db.Uuid
  start_time DateTime  @db.Timestamptz(6)
  end_time   DateTime  @db.Timestamptz(6)
  reason     String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  tenants    tenants?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model operating_hours {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String?  @db.Uuid
  day_of_week Int
  open_time   String   @db.VarChar(5)
  close_time  String   @db.VarChar(5)
  
  // === CAMPOS DE ALMOÇO (Adicionados) ===
  lunch_start String?  @db.VarChar(5)
  lunch_end   String?  @db.VarChar(5)
  
  is_closed   Boolean? @default(false)

  tenants     tenants? @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

// ==========================================================
// ⭐ AVALIAÇÕES (Reviews)
// ==========================================================
model reviews {
  id         String      @id @default(uuid()) @db.Uuid
  tenant_id  String      @db.Uuid
  client_id  String      @db.Uuid
  rating     Int         // 1 a 5
  comment    String?     @db.VarChar(500)
  created_at DateTime    @default(now()) @db.Timestamptz(6)

  tenant     tenants     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client     app_clients @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}